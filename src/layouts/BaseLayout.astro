---
import SEO from '../components/SEO.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  ogType?: string;
  schemaType?: 'LocalBusiness' | 'BlogPosting' | 'AboutPage' | 'ContactPage' | 'ImageGallery' | 'WebApplication' | 'CollectionPage';
  schemaData?: Record<string, any>;
  faq?: Array<{ question: string; answer: string }>;
}

const { title, description, canonical, image, ogType, schemaType, schemaData, faq } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <SEO title={title} description={description} canonical={canonical} image={image} type={ogType} />
  <SchemaOrg type={schemaType} data={schemaData} faq={faq} />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
  <meta name="theme-color" content="#1B3A2D" />
</head>
<body class="bg-cream text-charcoal font-inter antialiased">
  <Header />
  <main class="pt-20">
    <slot />
  </main>
  <Footer />
  <CookieConsent />
</body>
</html>
