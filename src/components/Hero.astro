---
interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage: string;
  variant?: 'default' | 'split' | 'inner';
  videoSrc?: string;
  videoPoster?: string;
}

const { title, subtitle, tagline, ctaText, ctaLink, backgroundImage, variant = 'default', videoSrc, videoPoster } = Astro.props;

// Split title into words for animation
const words = title.split(' ');
---

{variant === 'split' ? (
  <!-- SPLIT HERO: video/image left, text right -->
  <section class="hero-split">
    <div class="hero-split-image">
      {videoSrc && (
        <video autoplay muted loop playsinline poster={videoPoster || backgroundImage}>
          <source src={videoSrc} type="video/mp4" />
        </video>
      )}
      <img src={videoPoster || backgroundImage} alt="Luxury Mediterranean villa garden with pool" width="1400" height="933" loading="eager" />
    </div>
    <div class="hero-split-text">
      {tagline && <p class="hero-tagline">{tagline}</p>}
      <h1 class="hero-title-cinema">
        {words.map(word => <span class="word">{word} </span>)}
      </h1>
      {subtitle && <p class="hero-subtitle-cinema">{subtitle}</p>}
      {ctaText && ctaLink && (
        <a href={ctaLink} class="hero-cta">{ctaText}</a>
      )}
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
    </div>
  </section>
) : (
  <!-- DEFAULT / INNER HERO -->
  <section class:list={['hero-cinema', variant === 'inner' && 'hero-inner']}>
    <img
      src={backgroundImage}
      alt=""
      class="hero-bg"
      loading="eager"
      width="1920"
      height="1280"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content-cinema">
      {tagline && <p class="hero-tagline">{tagline}</p>}
      <h1 class="hero-title-cinema">
        {words.map(word => <span class="word">{word} </span>)}
      </h1>
      {subtitle && <p class="hero-subtitle-cinema">{subtitle}</p>}
      {ctaText && ctaLink && (
        <a href={ctaLink} class="hero-cta">{ctaText}</a>
      )}
    </div>
    {variant === 'default' && (
      <div class="hero-scroll">
        <span>Scroll</span>
        <div class="hero-scroll-line"></div>
      </div>
    )}
  </section>
)}
