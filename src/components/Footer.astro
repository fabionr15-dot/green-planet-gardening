  <div class="footer-bottom-cinema" style="max-width:1200px;margin:0 auto;">
    <span>&copy; 2025 – {year} Green Planet Gardening. All rights reserved.</span>
    <span>HE402756</span>
  </div>
</footer>

<script>
  // Email obfuscation - reveal on load
  document.querySelectorAll('[data-email]').forEach(el => {
    const email = el.getAttribute('data-email');
    const domain = el.getAttribute('data-domain');
    if (email && domain) {
      const full = `${email}@${domain}`;
      el.textContent = full;
      el.setAttribute('href', `mailto:${full}`);
    }
  });
</script>
