---
interface GalleryImage {
  src: string;
  alt: string;
  category: string;
}

interface Props {
  images: GalleryImage[];
  showFilters?: boolean;
}

const { images, showFilters = false } = Astro.props;
const categories = ['All', ...new Set(images.map(img => img.category))];
---

{showFilters && (
  <div class="flex flex-wrap justify-center gap-3 mb-10" id="gallery-filters">
    {categories.map((cat, i) => (
      <button
        class:list={[
          'gallery-filter px-5 py-2 text-sm uppercase tracking-wider rounded transition-colors',
          i === 0 ? 'bg-forest text-cream' : 'bg-sand/50 text-forest hover:bg-sand'
        ]}
        data-filter={cat}
      >
        {cat}
      </button>
    ))}
  </div>
)}

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6" id="gallery-grid">
  {images.map((img) => (
    <div class="gallery-item group relative overflow-hidden rounded-lg aspect-[4/3] cursor-pointer" data-category={img.category}>
      <img
        src={img.src}
        alt={img.alt}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
        loading="lazy"
        width="600"
        height="450"
      />
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
        <svg class="w-10 h-10 text-cream opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
      </div>
    </div>
  ))}
</div>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4" role="dialog" aria-label="Image viewer">
  <button id="lightbox-close" class="absolute top-4 right-4 text-cream/80 hover:text-cream z-10" aria-label="Close">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain rounded" />
</div>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');

  // Open lightbox
  document.querySelectorAll('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img');
      if (img && lightboxImg && lightbox) {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      }
    });
  });

  // Close lightbox
  function closeLightbox() {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.classList.remove('overflow-hidden');
  }
  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // Filter
  document.querySelectorAll('.gallery-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.gallery-filter').forEach(b => {
        b.classList.remove('bg-forest', 'text-cream');
        b.classList.add('bg-sand/50', 'text-forest');
      });
      btn.classList.add('bg-forest', 'text-cream');
      btn.classList.remove('bg-sand/50', 'text-forest');

      document.querySelectorAll('.gallery-item').forEach(item => {
        const cat = item.getAttribute('data-category');
        if (filter === 'All' || cat === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
