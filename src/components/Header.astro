---
import navigation from '../data/navigation.json';
const currentPath = Astro.url.pathname;
---

<header id="main-header" class="nav-cinematic">
  <div class="nav-left" style="display:flex;align-items:center;gap:14px;">
    <a href="/" style="display:flex;align-items:center;gap:14px;">
      <img src="/images/logo/green-planet-logo.png" alt="Green Planet Gardening" class="nav-logo-img-cinema" width="40" height="40" />
      <span class="nav-logo-text-cinema">Green Planet</span>
    </a>
  </div>

  <!-- Desktop Navigation -->
  <ul class="nav-links-cinema" style="display:flex;gap:32px;list-style:none;align-items:center;">
    {navigation.map((item: {label: string; href: string}) => {
      const isContact = item.href === '/contact';
      const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));

      return isContact ? (
        <li>
          <a href={item.href} class="nav-contact-btn-cinema">
            {item.label}
          </a>
        </li>
      ) : (
        <li>
          <a
            href={item.href}
            class:list={['nav-link-cinema', isActive && 'active']}
          >
            {item.label}
          </a>
        </li>
      );
    })}
  </ul>

  <!-- Mobile Hamburger -->
  <button class="nav-hamburger-cinema" id="hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu-cinema" id="mobileMenu">
  {navigation.map((item: {label: string; href: string}) => (
    <a
      href={item.href}
      class:list={[currentPath === item.href && 'active']}
      style={currentPath === item.href ? 'color: var(--color-gold)' : ''}
    >
      {item.label}
    </a>
  ))}
</div>

<script>
  // ─── Navbar scroll ───
  const navbar = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (navbar) navbar.classList.toggle('scrolled', window.scrollY > 80);
  }, { passive: true });

  // ─── Mobile Menu ───
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      mobileMenu.classList.toggle('open');
      hamburger.setAttribute('aria-expanded', String(mobileMenu.classList.contains('open')));
      document.body.classList.toggle('overflow-hidden');
    });
    mobileMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        document.body.classList.remove('overflow-hidden');
      });
    });
  }

  // ─── Hero Animations ───
  window.addEventListener('load', () => {
    const words = document.querySelectorAll('.hero-title-cinema .word');
    words.forEach((word, i) => {
      setTimeout(() => {
        (word as HTMLElement).style.opacity = '1';
        (word as HTMLElement).style.transform = 'translateY(0)';
      }, 400 + i * 150);
    });

    const tagline = document.querySelector('.hero-tagline') as HTMLElement;
    if (tagline) {
      setTimeout(() => {
        tagline.style.opacity = '1';
        tagline.style.transform = 'translateY(0)';
        tagline.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      }, 200);
    }

    const sub = document.querySelector('.hero-subtitle-cinema') as HTMLElement;
    if (sub) {
      setTimeout(() => {
        sub.style.opacity = '1';
        sub.style.transform = 'translateY(0)';
        sub.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      }, 1200);
    }

    const cta = document.querySelector('.hero-cta') as HTMLElement;
    if (cta) {
      setTimeout(() => {
        cta.style.opacity = '1';
        cta.style.transform = 'translateY(0)';
        cta.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      }, 1500);
    }
  });
</script>
