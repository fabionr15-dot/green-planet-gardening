---
---
<form
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-6"
  id="contact-form"
>
  <input type="hidden" name="form-name" value="contact" />

  <!-- Honeypot -->
  <div style="position: absolute; left: -9999px;" aria-hidden="true">
    <label for="bot-field">Leave this empty</label>
    <input type="text" name="bot-field" id="bot-field" tabindex="-1" autocomplete="off" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="name" class="block text-sm font-medium text-forest mb-2">Full Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        maxlength="100"
        pattern="[A-Za-zÀ-ÿ\s\-']+"
        class="w-full px-4 py-3 border border-sand rounded bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="Your name"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-forest mb-2">Email Address *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        maxlength="254"
        class="w-full px-4 py-3 border border-sand rounded bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="your@email.com"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="phone" class="block text-sm font-medium text-forest mb-2">Phone Number</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        maxlength="20"
        pattern="[\d\s\+\-\(\)]+"
        class="w-full px-4 py-3 border border-sand rounded bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
        placeholder="+357 99 000 000"
      />
    </div>
    <div>
      <label for="project-type" class="block text-sm font-medium text-forest mb-2">Project Type</label>
      <select
        id="project-type"
        name="project-type"
        class="w-full px-4 py-3 border border-sand rounded bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
      >
        <option value="">Select a type...</option>
        <option value="Garden Design">Garden Design</option>
        <option value="Maintenance">Maintenance</option>
        <option value="Consulting">Consulting</option>
        <option value="Other">Other</option>
      </select>
    </div>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-forest mb-2">Message *</label>
    <textarea
      id="message"
      name="message"
      required
      maxlength="2000"
      rows="5"
      class="w-full px-4 py-3 border border-sand rounded bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-y"
      placeholder="Tell us about your project..."
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full sm:w-auto bg-gold text-white px-10 py-4 text-sm uppercase tracking-wider hover:bg-amber-600 transition-colors rounded font-medium"
  >
    Send Message
  </button>

  <div id="form-success" class="hidden text-sage font-medium text-center py-4">
    Thank you! We'll get back to you within 24 hours.
  </div>
  <div id="form-error" class="hidden text-red-600 font-medium text-center py-4">
    Something went wrong. Please try again or contact us directly.
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  // Sanitize input
  function sanitize(input: string): string {
    return input
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#x27;')
      .replace(/\//g, '&#x2F;');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    success?.classList.add('hidden');
    error?.classList.add('hidden');

    // Check honeypot
    const honeypot = (form.querySelector('[name="bot-field"]') as HTMLInputElement)?.value;
    if (honeypot) return;

    const data = new FormData(form);

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
      if (res.ok) {
        success?.classList.remove('hidden');
        form.reset();
      } else {
        error?.classList.remove('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
