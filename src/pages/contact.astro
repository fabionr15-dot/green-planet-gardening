---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Green Planet Gardening - Luxury Landscaping Experts, Cyprus"
  description="Get in touch with Green Planet Gardening's luxury landscaping experts in Cyprus. Contact us for a consultation via phone, WhatsApp, or our online form."
  schemaType="ContactPage"
>
  <Hero
    title="Contact Us"
    subtitle="For inquiries, consultation bookings or additional information, our family team is here to assist you. Simply fill out the contact form or give us a call. We look forward to helping you create your ideal outdoor space."
    backgroundImage="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1920&q=80&fit=crop&crop=center"
    variant="inner"
  />

  <!-- Contact Section -->
  <section class="section-padding">
    <div class="contact-grid">

      <!-- LEFT: Form -->
      <div>
        <ContactForm />
      </div>

      <!-- RIGHT: Contact Info Card -->
      <div>
        <div class="contact-info-card reveal">
          <h3>Get in Touch</h3>

          <div class="contact-info-item">
            <div class="label">Email</div>
            <div class="value"><a href="#" data-email="hello" data-domain="greenplanetgardening.eu">Loading...</a></div>
          </div>

          <div class="contact-info-item">
            <div class="label">Phone</div>
            <div class="value"><a href="tel:+35799245332">+357 99 245 332</a></div>
          </div>

          <div class="contact-info-item">
            <div class="label">WhatsApp</div>
            <div class="value"><a href="https://api.whatsapp.com/send?phone=35796541879" target="_blank" rel="noopener noreferrer">+357 96 541 879</a></div>
          </div>

          <div class="contact-info-item">
            <div class="label">Hours</div>
            <div class="value">Monday – Saturday, 8:00 AM – 7:00 PM</div>
          </div>

          <div class="contact-info-item">
            <div class="label">Location</div>
            <div class="value">Paphos, Cyprus</div>
          </div>

          <div class="contact-social">
            <a href="https://facebook.com/GreenPlanetCy" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://instagram.com/green.planet.cy/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://api.whatsapp.com/send?phone=35796541879" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Below form text -->
  <section class="section-padding" style="background:var(--color-cream);">
    <div class="section-max" style="text-align:center;">
      <p class="section-text reveal" style="margin-bottom:16px;">
        Your garden begins with a conversation. Green Planet Gardening welcomes you to reach out and take the first step toward a beautifully designed outdoor space. Our <a href="/about" style="color:var(--color-gold);">family team of experts</a> is here to guide you through every stage of your project, from the first idea to the final touch of green.
      </p>
      <p class="section-text reveal reveal-delay-1">
        Whether you are planning a complete <a href="/services" style="color:var(--color-gold);">garden transformation</a>, need professional maintenance for your villa or resort, or want advice on Mediterranean plants and irrigation systems, we are ready to help. Explore our <a href="/gallery" style="color:var(--color-gold);">project portfolio</a> for inspiration, or try our <a href="/plant-ai" style="color:var(--color-gold);">Plant AI identifier</a> while you wait. Every message is answered personally by one of the three founders.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  // Email obfuscation reveal
  document.querySelectorAll('[data-email]').forEach(el => {
    const email = el.getAttribute('data-email');
    const domain = el.getAttribute('data-domain');
    if (email && domain) {
      const full = `${email}@${domain}`;
      el.textContent = full;
      el.setAttribute('href', `mailto:${full}`);
    }
  });
</script>
