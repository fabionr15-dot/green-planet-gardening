---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WaveDivider from '../components/WaveDivider.astro';
import Testimonials from '../components/Testimonials.astro';
import services from '../data/services.json';
import galleryData from '../data/gallery.json';

const showcaseImages = galleryData.filter(img =>
  ['6f86d623', '15757', 'd50_6815', 'd50_6847', 'd50_7072', 'z62_0988-2'].some(name => img.src.includes(name))
);
---

<BaseLayout
  title="Luxury Landscaping in Cyprus | Green Planet Gardening"
  description="Bespoke gardens for villas, resorts & residences in Paphos, Limassol, and across Cyprus. Family-run luxury landscaping for over 10 years."
  faq={[
    { question: "What is Green Planet Gardening?", answer: "Green Planet Gardening is a family-run luxury landscaping company based in Paphos, Cyprus. Founded by three brothers — Charalambos, Marios, and Angelos Knodaritis — the company has over 10 years of experience creating bespoke gardens for private villas, resorts, and high-end residences across Cyprus." },
    { question: "What services does Green Planet Gardening provide?", answer: "Green Planet Gardening offers luxury garden design and construction, professional maintenance and green management, and tailored consulting for architects and investors. Services include hardscaping, softscaping, irrigation, outdoor lighting, and ongoing garden care programmes." },
    { question: "Where does Green Planet Gardening operate?", answer: "Green Planet Gardening is headquartered in Paphos and serves all regions of Cyprus, including Limassol, Nicosia, Larnaca, and resort areas. The company specialises in Mediterranean landscaping suited to the local climate." },
  ]}
>
  <!-- Split Hero with Video -->
  <Hero
    title="Where Nature Meets Excellence"
    subtitle="Luxury landscaping for private villas, resorts, and high-end residences across Cyprus. Designed by three brothers who believe every garden tells a unique story."
    tagline="Passion · Precision · Trust · Timeless"
    ctaText="Request a Consultation"
    ctaLink="/contact"
    backgroundImage="/images/hero/hero-home.jpg"
    variant="split"
    videoSrc="https://videos.pexels.com/video-files/3614910/3614910-hd_1920_1080_24fps.mp4"
    videoPoster="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=1400&q=80&fit=crop&crop=center"
  />

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="trust-item reveal" style="--i:0">
      <div class="trust-number" data-count="10" data-suffix="+">0+</div>
      <div class="trust-label">Years of Excellence</div>
    </div>
    <div class="trust-item reveal" style="--i:1">
      <div class="trust-number" data-count="3" data-suffix="">0</div>
      <div class="trust-label">Family Brothers</div>
    </div>
    <div class="trust-item reveal" style="--i:2">
      <div class="trust-number" data-count="5" data-suffix="★">0★</div>
      <div class="trust-label">Client Reviews</div>
    </div>
    <div class="trust-item reveal" style="--i:3">
      <div class="trust-number" data-count="1" data-suffix="">0</div>
      <div class="trust-label">Paphos, Cyprus</div>
    </div>
  </div>

  <!-- Wave Divider -->
  <WaveDivider topColor="#1B3A2D" bottomColor="#FAF8F5" />

  <!-- Welcome — Split Section with Overlap Card -->
  <section style="background:var(--color-cream);">
    <div class="split-section">
      <div class="split-image-wrapper">
        <div class="image-reveal">
          <img class="split-image" src="/images/projects/d50_6994.jpg" alt="Luxury Mediterranean landscaping by Green Planet Gardening Cyprus with natural climbing plants and elegant architectural greenery." loading="lazy" width="800" height="600" />
        </div>
      </div>
      <div class="split-content">
        <div class="overlap-card">
          <span class="section-tag reveal">Welcome</span>
          <h2 class="section-title reveal reveal-delay-1">Welcome to Green Planet Gardening</h2>
          <div class="section-line reveal reveal-delay-2"></div>
          <p class="section-text reveal reveal-delay-2">
            Welcome to Green Planet Gardening, a Cypriot company where nature turns into art and gardening becomes an emotion. We are three brothers, united by a shared passion for earth, beauty, and perfection. We believe that every garden tells a unique story, a reflection of the soul of those who live it.
          </p>
          <p class="section-text reveal reveal-delay-3" style="margin-top:16px;">
            For more than a decade, we have been creating luxury gardens and bespoke green spaces for private villas, resorts, and high-end residences across Cyprus. Every project begins with listening — grows through craftsmanship — and comes to life through a balance of art, precision, and emotion.
          </p>
          <a href="/about" class="reveal reveal-delay-3" style="display:inline-block;margin-top:28px;color:var(--color-gold);font-size:12px;letter-spacing:0.15em;text-transform:uppercase;">
            Learn About Us →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy — Reverse Split Section -->
  <section style="background:var(--color-cream);">
    <div class="split-section reverse">
      <div class="split-image-wrapper">
        <div class="image-reveal">
          <img class="split-image" src="/images/projects/d50_6975.jpg" alt="Luxury garden pathway by Green Planet Gardening Cyprus featuring premium stone design, structured greenery and elegant Mediterranean outdoor architecture." loading="lazy" width="800" height="600" />
        </div>
      </div>
      <div class="split-content">
        <div class="overlap-card">
          <span class="section-tag reveal">Our Philosophy</span>
          <h2 class="section-title reveal reveal-delay-1">Creating Emotions That Last Over Time</h2>
          <div class="section-line reveal reveal-delay-2"></div>
          <p class="section-text reveal reveal-delay-2">
            Green Planet Gardening is not just a landscaping company, it is a family. Every day, we work with the same passion that brought us together, guided by the belief that quality is not a goal — it's a way of life.
          </p>
          <p class="section-text reveal reveal-delay-3" style="margin-top:16px;">
            We believe in perfection through detail, in the authentic beauty of nature, and in trust as our most valuable promise. In Cyprus's high-end landscaping world, we offer the same level of expertise and craftsmanship as the five major groups, but with a soul that's more personal, more human, and truly our own.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dark Quote Section -->
  <section class="quote-section">
    <p class="quote-text reveal">
      "Every client who chooses us knows that our work grows from three solid roots: <span class="highlight">quality, trust, and professionalism</span>. We never promise more than we can do, yet we always deliver more than expected."
    </p>
    <p class="quote-author reveal reveal-delay-1">— Green Planet Gardening</p>
    <div class="quote-deco reveal reveal-delay-2"></div>
  </section>

  <!-- Services — Cinematic Cards -->
  <section class="section-padding" style="background:var(--color-cream);">
    <div class="section-max section-center">
      <span class="section-tag reveal">What We Do</span>
      <h2 class="section-title reveal reveal-delay-1" style="text-align:center;">Our Services and Expertise</h2>
      <p class="section-text reveal reveal-delay-2" style="text-align:center;max-width:600px;margin:0 auto 48px;">We offer a complete range of landscape design and green care services:</p>
    </div>
    <div class="services-grid-cinema">
      {services.map((s: any, i: number) => (
        <a href="/services" class="service-card-cinema reveal" style={`--i:${i}`} data-image-hover>
          <img src={s.image} alt={s.alt} loading="lazy" width="600" height="800" />
          <div class="service-card-content">
            <div class="service-card-line"></div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Horizontal Gallery -->
  <section class="gallery-section">
    <div class="section-center" style="padding:0 48px 48px;">
      <span class="section-tag reveal" style="color:var(--color-gold);">Portfolio</span>
      <h2 class="section-title reveal reveal-delay-1" style="color:white;text-align:center;">Exclusive Projects — Our Signature in Nature</h2>
      <p class="reveal reveal-delay-2" style="color:rgba(255,255,255,0.6);text-align:center;max-width:600px;margin:0 auto;font-size:16px;line-height:1.8;font-weight:300;">
        Every garden signed by Green Planet is a story of harmony and perfection. We take on only a few projects each year, because every creation deserves time, attention, and soul.
      </p>
    </div>
    <div class="gallery-track">
      {showcaseImages.map((img: any) => (
        <div class="gallery-h-item" data-image-hover>
          <img src={img.src} alt={img.alt} loading="lazy" width="800" height="1000" />
          <div class="gallery-item-overlay">
            <div class="gallery-item-title">{img.alt.split(' by ')[0].substring(0, 40)}</div>
            <div class="gallery-item-cat">{img.category}</div>
          </div>
        </div>
      ))}
    </div>
    <div class="gallery-drag-hint">← Drag to explore →</div>
    <div style="text-align:center;padding-bottom:40px;">
      <a href="/gallery" class="cta-btn-outline" style="border-color:rgba(255,255,255,0.2);">See All Projects</a>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- Why Choose Us — Value Cards -->
  <section class="section-padding" style="background:var(--color-cream);">
    <div class="section-max section-center">
      <span class="section-tag reveal">Why Us</span>
      <h2 class="section-title reveal reveal-delay-1" style="text-align:center;">Why Choose Green Planet Gardening</h2>
      <div style="height:48px;"></div>
    </div>
    <div class="values-grid">
      <div class="value-card reveal" style="--i:0">
        <div class="value-icon">✦</div>
        <h3>Boutique Approach</h3>
        <p>We take on only a few projects each year. Every garden gets our full attention.</p>
      </div>
      <div class="value-card reveal" style="--i:1">
        <div class="value-icon">♥</div>
        <h3>Family Values</h3>
        <p>Three brothers, one shared passion. We treat your garden like our own.</p>
      </div>
      <div class="value-card reveal" style="--i:2">
        <div class="value-icon">🌍</div>
        <h3>Mediterranean Expertise</h3>
        <p>10+ years mastering Cyprus's unique climate, soil, and plant life.</p>
      </div>
      <div class="value-card reveal" style="--i:3">
        <div class="value-icon">👁</div>
        <h3>Invisible Perfection</h3>
        <p>The details you don't see at first glance define perfection over time.</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <span class="section-tag reveal" style="text-align:center;">Ready?</span>
    <h2 class="reveal reveal-delay-1">Your Garden Begins with a Conversation</h2>
    <p class="reveal reveal-delay-2">
      Ready to transform your outdoor space into a living masterpiece? Whether you're planning a complete garden transformation, need professional maintenance, or want expert advice — we're here to help.
    </p>
    <div class="reveal reveal-delay-3">
      <a href="/contact" class="cta-btn">Request a Consultation</a>
      <a href="https://api.whatsapp.com/send?phone=35796541879" target="_blank" rel="noopener noreferrer" class="cta-btn-outline">WhatsApp Us</a>
    </div>
  </section>
</BaseLayout>
