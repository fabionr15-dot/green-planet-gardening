---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import galleryData from '../data/gallery.json';

const categories = ['all', ...new Set(galleryData.map((img: any) => img.category))];
---

<BaseLayout
  title="Luxury Garden Projects in Cyprus | Green Planet Gardening"
  description="Explore our portfolio of luxury garden projects across Cyprus. Private villa gardens, resort landscapes and terraces crafted with Mediterranean expertise."
  schemaType="ImageGallery"
>
  <Hero
    title="Our Projects"
    subtitle="Every garden signed by Green Planet is a story of harmony and perfection. We take on only a few projects each year, because every creation deserves time, attention, and soul. Browse our portfolio to see the care and craftsmanship that defines our work."
    backgroundImage="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1920&q=80&fit=crop&crop=center"
    variant="inner"
  />

  <!-- Gallery Section -->
  <section class="section-padding" style="background:var(--color-cream);">
    <div class="section-max">

      <!-- Filter Buttons -->
      <div class="gallery-filter">
        {categories.map((cat: string) => (
          <button class:list={['filter-btn', cat === 'all' ? 'active' : '']} data-filter={cat}>
            {cat === 'all' ? 'All' : cat}
          </button>
        ))}
      </div>

      <!-- Gallery Grid -->
      <div class="gallery-grid">
        {galleryData.map((img: any) => (
          <div class="gallery-grid-item reveal" data-category={img.category} data-image-hover>
            <img src={img.src} alt={img.alt} loading="lazy" width="600" height="450" />
            <div class="item-overlay">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4" role="dialog" aria-label="Image viewer">
    <button id="lightbox-close" class="absolute top-4 right-4 text-cream/80 hover:text-cream z-10" aria-label="Close">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain rounded" />
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <h2 class="reveal">Inspired by What You See?</h2>
    <p class="reveal reveal-delay-1">Every project in our portfolio started with a conversation. Explore our <a href="/services" style="color:var(--color-gold);">full range of services</a> or get in touch to start yours.</p>
    <div class="reveal reveal-delay-2">
      <a href="/contact" class="cta-btn">Contact Us</a>
      <a href="/services" class="cta-btn-outline">View Services</a>
    </div>
  </section>
</BaseLayout>

<script>
  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');

  document.querySelectorAll('.gallery-grid-item').forEach(item => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img');
      if (img && lightboxImg && lightbox) {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      }
    });
  });

  function closeLightbox() {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.classList.remove('overflow-hidden');
  }
  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
