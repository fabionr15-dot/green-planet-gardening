---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import galleryData from '../data/gallery.json';
---

<BaseLayout
  title="Luxury Garden Designs | Green Planet Gardening Portfolio"
  description="Explore our portfolio of luxury garden projects across Cyprus. Private villa gardens, resort landscapes and terraces crafted with Mediterranean expertise."
  schemaType="ImageGallery"
>
  <!-- Hero -->
  <section class="py-20 bg-forest">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-playfair text-cream mb-6">Our Projects</h1>
      <p class="text-cream/80 leading-relaxed">
        Every garden signed by Green Planet is a story of harmony and perfection. We take on only a few projects each year, because every creation deserves time, attention, and soul. Browse our portfolio to see the care and craftsmanship that defines our work.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Gallery images={galleryData} showFilters={true} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-sand/20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-playfair text-forest mb-6">Inspired by What You See?</h2>
      <p class="text-charcoal/70 leading-relaxed mb-8">Every project in our portfolio started with a conversation. Explore our <a href="/services" class="text-gold hover:text-amber-600 transition-colors">full range of services</a> or get in touch to start yours.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-block bg-gold text-white px-8 py-4 text-sm uppercase tracking-wider hover:bg-amber-600 transition-colors rounded font-medium">
          Contact Us
        </a>
        <a href="/services" class="inline-block border border-forest text-forest px-8 py-4 text-sm uppercase tracking-wider hover:bg-forest hover:text-cream transition-colors rounded font-medium">
          View Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
